# Database
POSTGRES_DB=sotka
POSTGRES_USER=sotka
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL=postgresql+asyncpg://sotka:change_me_in_production@db:5432/sotka

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change_me_to_random_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Claude API (for AI assessment)
ANTHROPIC_API_KEY=sk-ant-...

# Email (alerts)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your_smtp_password

# Telegram bot (alerts)
TELEGRAM_BOT_TOKEN=your_bot_token

# ЮКасса (payments)
YUKASSA_SHOP_ID=your_shop_id
YUKASSA_SECRET_KEY=your_secret_key

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILES=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Scraping delays (seconds) — be respectful to servers
TORGI_GOV_DELAY=1.0
AVITO_DELAY=3.0
